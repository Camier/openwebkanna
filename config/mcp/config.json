{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/data",
        "/thesis-exports"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "zotero": {
      "command": "npx",
      "args": [
        "-y",
        "zotero-bridge",
        "--db",
        "/zotero/zotero.sqlite",
        "--readonly"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=Europe/Paris"
      ]
    },
    "gis": {
      "command": "uvx",
      "args": [
        "gis-mcp"
      ]
    },
    "qgis": {
      "command": "/LAB/@creative/QGIS/vendor/qgis_mcp/.venv/bin/python",
      "args": [
        "src/qgis_mcp/qgis_mcp_server.py"
      ],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      },
      "workingDirectory": "/LAB/@creative/QGIS/vendor/qgis_mcp"
    }
  }
}
